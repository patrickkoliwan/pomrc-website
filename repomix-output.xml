import {
  FaCalendarAlt,
  FaMapMarkerAlt,
  FaClock,
  FaMoneyBillWave,
} from "react-icons/fa";
import type { JuniorProgram } from "@/data/juniorPrograms";

interface ProgramCardProps {
  program: JuniorProgram;
  isPriority?: boolean;
