export default async function Events() {
  const cmsEvents = await getPublishedEvents();
  const mappedEvents = cmsEvents.map((event) => ({
    id: event.id,
    title: event.title,
    description: event.description || "",
    date: event.event_date || event.day || "Date to be confirmed",
    time:
