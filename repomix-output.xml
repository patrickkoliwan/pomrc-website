        <div>
          <label
            htmlFor="junior-program-notice-section"
            className="block text-sm font-medium text-dark-teal"
          >
            Placement
          </label>
          <select
            id="junior-program-notice-section"
            value={form.section}
            onChange={(event) =>
              setForm((current) => ({
                ...current,
                section: event.target.value as JuniorProgramNoticeSection,
              }))
